services:
  broker:
    image: bjorkan/meshcore-mqtt-broker:latest
    restart: unless-stopped
    env_file:
      - ./broker/.env
    ports:
      - "8883:8883"
    volumes:
      - broker-data:/data

  bridge:
    image: bjorkan/meshcore-mqtt-broker-bridge:latest
    restart: unless-stopped
    depends_on:
      - broker
    env_file:
      - ./bridge/.env

volumes:
  broker-data:
