services:
  broker:
    image: bjorkan/meshcore-mqtt-broker:latest
    restart: unless-stopped
    env_file:
      - ./broker/.env
    ports:
      - "8883:8883"
    depends_on:
      - valkey

  valkey:
    image: valkey/valkey:8-alpine
    restart: unless-stopped
    command: ["valkey-server", "--appendonly", "yes"]
    volumes:
      - valkey-data:/data

  bridge:
    image: bjorkan/meshcore-mqtt-broker-bridge:latest
    restart: unless-stopped
    depends_on:
      - broker
    env_file:
      - ./bridge/.env

volumes:
  valkey-data:
