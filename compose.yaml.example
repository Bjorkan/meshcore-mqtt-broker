services:
  meshcore-mqtt-broker:
    image: bjorkan/meshcore-mqtt-broker:latest
    restart: unless-stopped
    volumes:
      - ./broker/config.yaml:/run/configs/meshcore-mqtt-broker-config.yaml:ro
    ports:
      - "8883:8883"
    depends_on:
      - valkey

  valkey:
    image: valkey/valkey:9-alpine
    restart: unless-stopped
    command: ["valkey-server", "--appendonly", "yes"]
    volumes:
      - valkey-data:/data

  meshcore-mqtt-broker-bridge:
    image: bjorkan/meshcore-mqtt-broker-bridge:latest
    restart: unless-stopped
    depends_on:
      - meshcore-mqtt-broker
    env_file:
      - ./bridge/.env

volumes:
  valkey-data:
