# Source broker subscription
BRIDGE_MQTT_URL=ws://broker:8883
BRIDGE_MQTT_USERNAME=uplink
BRIDGE_MQTT_PASSWORD=change-this-password
TOPIC_FILTER=meshcore/#
BRIDGE_CLIENT_ID=meshcore-uplink-source

# Target broker publish destination
TARGET_MQTT_URL=mqtts://mqtt.example.com:8883
TARGET_MQTT_USERNAME=
TARGET_MQTT_PASSWORD=
TARGET_PREFIX=
TARGET_CLIENT_ID=meshcore-uplink-target

# Heartbeat publish destination on the target broker
HEARTBEAT_ENABLED=true
HEARTBEAT_TOPIC=mshse/Hjärtslag
HEARTBEAT_MESSAGE=Hjärtat slår
HEARTBEAT_INTERVAL_MS=30000
