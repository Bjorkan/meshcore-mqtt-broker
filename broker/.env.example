# MeshCore MQTT Broker Configuration
# Copy this file to .env and fill in your values

# MQTT Server Settings
# Port must be an integer from 0 to 65535 (0 lets the OS choose a free port).
MQTT_WS_PORT=8883
MQTT_HOST=0.0.0.0
# Maxstorlek för inkommande WebSocket/MQTT-frame innan data skickas till Aedes.
# Must be a positive integer.
MQTT_WS_MAX_PAYLOAD_BYTES=65536
# Maxstorlek för normal JSON-publish innan JSON.parse körs.
# Must be a positive integer.
MQTT_JSON_PUBLISH_MAX_BYTES=8192
# TTL for cached node names in ms. Must be a positive integer.
BROKER_NODE_NAME_CACHE_TTL_MS=86400000

# Orchestration / Docker Swarm
# Valkey is always required. It provides MQTT cluster routing and global subscriber connection limits.
# Valkey uses the Redis protocol, so redis:// is expected.
BROKER_KV_URL=redis://valkey:6379
BROKER_KV_NAMESPACE=meshcore-mqtt-broker
# Defaults to HOSTNAME. Set explicitly if your orchestrator does not provide stable container hostnames.
# BROKER_INSTANCE_ID=broker-1

# Lita bara på CF-Connecting-IP/X-Forwarded-For/X-Real-IP från betrodda proxies.
# Lämna avstängt om brokern kan nås direkt.
TRUST_PROXY=false
# Comma-separated CIDRs for reverse proxies. If TRUST_PROXY=true and this is
# omitted, only loopback (127.0.0.1/32, ::1/128) is trusted.
# TRUSTED_PROXY_CIDRS=172.18.0.0/16,10.0.0.0/8

# Authentication Settings
# Expected audience claim in JWT tokens (e.g., mqtt.yourdomain.com)
# Leave empty to skip audience validation
AUTH_EXPECTED_AUDIENCE=mqtt.yourdomain.com

# Subscribe-Only Users (one per line, format: username:password:role:maxConnections)
# Role: 1=admin (full access + can delete retained), 2=full_access (no hidden data), 3=limited (filtered data)
# Default role is 3 (limited) if not specified
# maxConnections: number for override, D or omit to use default (SUBSCRIBER_MAX_CONNECTIONS_DEFAULT)
# Add as many as you need by incrementing the number
# Must be a positive integer.
SUBSCRIBER_MAX_CONNECTIONS_DEFAULT=2
SUBSCRIBER_1=viewer1:your-secure-password-here:2
SUBSCRIBER_2=admin:admin-password-here:1:10
SUBSCRIBER_3=limited:limited-password:3:D
SUBSCRIBER_4=uplink:change-this-password:2:1
# ... add more as needed

# Docker Healthcheck
# The broker automatically creates the docker_health runtime user on every start.
# It writes a fresh 32-character password to the file below; the healthcheck reads
# the same file and authenticates before running an MQTT publish/subscribe loopback check.
HEALTHCHECK_MQTT_TIMEOUT_MS=10000
# HEALTHCHECK_MQTT_KEEPALIVE_SECONDS=60
# HEALTHCHECK_MQTT_CREDENTIALS_FILE=/tmp/meshcore-mqtt-broker/docker_health_credentials.json
# HEALTHCHECK_MQTT_URL=ws://127.0.0.1:8883


# Abuse Detection - Enforcement
# Must be true or false.
ABUSE_ENFORCEMENT_ENABLED=false

# Abuse Detection - Duplicate Detection
# All windows, sizes, thresholds, and counts must be valid non-zero integers unless noted.
ABUSE_DUPLICATE_WINDOW_SIZE=100
ABUSE_DUPLICATE_WINDOW_MS=300000
ABUSE_DUPLICATE_THRESHOLD=10
ABUSE_MAX_DUPLICATES_PER_PACKET=5
# Float from 0 to 1.
ABUSE_DUPLICATE_RATE_THRESHOLD=0.3
ABUSE_DUPLICATE_RATE_WINDOW_MS=300000

# Abuse Detection - Rate Limiting
# Must be a positive integer.
ABUSE_BUCKET_CAPACITY=20
# Must be greater than 0.
ABUSE_BUCKET_REFILL_RATE=3

# Abuse Detection - Anomaly Detection
ABUSE_MAX_PACKET_SIZE=255
ABUSE_MAX_TOPICS_PER_DAY=3
ABUSE_ANOMALY_THRESHOLD=10

# Abuse Detection - IATA Change Observation
# Region changes are always allowed; this threshold only marks notable churn in logs/internal telemetry.
ABUSE_MAX_IATA_CHANGES_24H=3

# Abuse Detection - Topic Tracking
ABUSE_TOPIC_HISTORY_SIZE=50
ABUSE_TOPIC_HISTORY_WINDOW_MS=86400000

# Optional: Comma-separated list of extra allowed region codes.
# These are added on top of allowed_regions.yaml.
# If neither allowed_regions.yaml nor ALLOWED_REGIONS contains a code, region publishes are denied.
# ALLOWED_REGIONS=ORD,MDW,RFD
