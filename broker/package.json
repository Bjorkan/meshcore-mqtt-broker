{
  "name": "meshcore-mqtt-broker",
  "version": "1.0.0",
  "description": "MeshCore MQTT broker with public key authentication",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "build": "tsc && esbuild src/dashboard-client.tsx --bundle --format=esm --platform=browser --target=es2020 --define:process.env.NODE_ENV=\\\"production\\\" --minify --outfile=dist/public/dashboard-client.js --log-level=warning",
    "test": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "start": "tsx src/server.ts"
  },
  "keywords": [
    "meshcore",
    "mqtt",
    "broker"
  ],
  "author": "Michael Hart <michaelhart@michaelhart.me> (https://github.com/michaelhart)",
  "license": "MIT",
  "dependencies": {
    "@michaelhart/meshcore-decoder": "^0.3.0",
    "aedes": "^1.0.2",
    "aedes-persistence-redis": "^11.2.2",
    "dotenv": "^17.4.2",
    "ini": "^7.0.0",
    "ioredis": "^5.11.1",
    "mqemitter-redis": "^7.2.0",
    "mqtt": "^5.15.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/ini": "^4.1.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
