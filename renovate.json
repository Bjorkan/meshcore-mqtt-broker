{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["npm", "dockerfile", "github-actions"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "ignoreTests": false,
  "packageRules": [
    {
      "description": "Keep GitHub artifact actions on the same version, but never above v7",
      "matchManagers": ["github-actions"],
      "matchPackageNames": [
        "actions/upload-artifact",
        "actions/download-artifact"
      ],
      "allowedVersions": "<8",
      "groupName": "GitHub artifact actions",
      "groupSlug": "github-artifact-actions",
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "automerge": true
    },
    {
      "description": "Automerge every dependency update after required checks pass",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "lockFileMaintenance",
        "bump",
        "replacement",
        "rollback"
      ],
      "automerge": true
    }
  ]
}
