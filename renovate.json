{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinDevDependencies",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    "abandonments:recommended",
    "security:openssf-scorecard"
  ],
  "enabledManagers": ["npm", "dockerfile", "github-actions"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "schedule": ["* 0-2 * * *"],
  "timezone": "Europe/Stockholm",
  "minimumReleaseAge": "14 days",
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "ignoreTests": false,
  "packageRules": [
    {
      "description": "Keep GitHub artifact actions on the same version, but never above v7",
      "matchManagers": ["github-actions"],
      "matchPackageNames": [
        "actions/upload-artifact",
        "actions/download-artifact"
      ],
      "allowedVersions": "<8",
      "groupName": "GitHub artifact actions",
      "groupSlug": "github-artifact-actions",
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "automerge": true
    },
    {
      "description": "Group ESLint-related packages with ESLint to keep peer deps compatible",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "eslint",
        "@eslint/js",
        "typescript-eslint",
        "eslint-plugin-react",
        "eslint-plugin-react-hooks",
        "eslint-config-prettier",
        "@typescript-eslint/{/,}**"
      ],
      "groupName": "ESLint + typescript-eslint",
      "groupSlug": "eslint-typescript-eslint",
      "automerge": true
    },
    {
      "description": "TODO: remove when typescript-eslint >=9 supports eslint 10",
      "matchManagers": ["npm"],
      "matchPackageNames": ["eslint", "@eslint/js"],
      "allowedVersions": "<10"
    }
  ]
}
